rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "ailogin.learn@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.role is string && (data.role == "patient" || data.role == "admin" || data.role == "doctor")
        && data.createdAt is string && data.createdAt.size() <= 128;
    }

    function isValidDoctor(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.department is string && data.department.size() <= 128
        && data.specialty is string && data.specialty.size() <= 128
        && data.imageUrl is string && data.imageUrl.size() <= 1024
        && data.experience is string && data.experience.size() <= 256;
    }

    function isValidAppointment(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.doctorId is string && data.doctorId.size() <= 128
        && data.doctorName is string && data.doctorName.size() <= 128
        && data.department is string && data.department.size() <= 128
        && data.date is string && data.date.size() <= 64
        && data.timeSlot is string && data.timeSlot.size() <= 64
        && data.status is string && (data.status == "pending" || data.status == "completed" || data.status == "cancelled")
        && data.createdAt is string && data.createdAt.size() <= 128
        && data.updatedAt is string && data.updatedAt.size() <= 128;
    }

    function isValidReport(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 256
        && data.fileUrl is string && data.fileUrl.size() <= 4096
        && data.fileName is string && data.fileName.size() <= 512
        && data.uploadDate is string && data.uploadDate.size() <= 128
        && data.fileSize is string && data.fileSize.size() <= 64;
    }

    function isValidBlog(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 256
        && data.excerpt is string && data.excerpt.size() <= 1024
        && data.content is string && data.content.size() <= 100000
        && data.authorName is string && data.authorName.size() <= 128
        && data.authorId is string && data.authorId.size() <= 128
        && data.category is string && data.category.size() <= 128
        && data.imageUrl is string && data.imageUrl.size() <= 2048
        && data.publishedDate is string && data.publishedDate.size() <= 128
        && data.readTime is string && data.readTime.size() <= 64
        && data.updatedAt is string && data.updatedAt.size() <= 128;
    }

    // --- Collection Routes ---
    
    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (incoming().role == "patient" || isAdmin() || incoming().email == "ailogin.learn@gmail.com");
      allow update: if isSignedIn() && (isAdmin() || (isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == existing().role && incoming().createdAt == existing().createdAt && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email'])
      )));
      allow delete: if isAdmin();
    }

    // Doctors Collection
    match /doctors/{doctorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Appointments Collection
    match /appointments/{appointmentId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(appointmentId) && isValidAppointment(incoming()) && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.userId == request.auth.uid && isValidAppointment(incoming()) && (
          incoming().userId == existing().userId &&
          incoming().doctorId == existing().doctorId &&
          incoming().doctorName == existing().doctorName &&
          incoming().department == existing().department &&
          incoming().date == existing().date &&
          incoming().timeSlot == existing().timeSlot &&
          incoming().createdAt == existing().createdAt &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'notes'])
        ))
      );
      allow delete: if isAdmin();
    }

    // Reports Collection
    match /reports/{reportId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(reportId) && isValidReport(incoming()) && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Blogs Collection
    match /blogs/{blogId} {
      allow read: if true;
      allow create: if isValidId(blogId) && isValidBlog(incoming());
      allow update: if isValidBlog(incoming());
      allow delete: if true;
    }
  }
}
